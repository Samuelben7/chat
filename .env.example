# ========================================
# WHATSAPP SYSTEM - ENVIRONMENT VARIABLES
# ========================================
# Copie este arquivo para .env e preencha os valores

# ========== DATABASE ==========
POSTGRES_DB=whatsapp_db
POSTGRES_USER=whatsapp_user
POSTGRES_PASSWORD=COLOQUE_UMA_SENHA_FORTE_AQUI

# ========== REDIS ==========
# Já configurado automaticamente pelo Docker

# ========== JWT AUTHENTICATION ==========
# Gere uma chave secreta com: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_AQUI_MINIMO_32_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========== WHATSAPP API (META) ==========
# Pegue no Meta Business: https://developers.facebook.com/apps
WHATSAPP_TOKEN=SEU_TOKEN_PERMANENTE_DA_META
PHONE_NUMBER_ID=SEU_PHONE_NUMBER_ID

# ========== APP CONFIG ==========
DEBUG=False
ENVIRONMENT=production
